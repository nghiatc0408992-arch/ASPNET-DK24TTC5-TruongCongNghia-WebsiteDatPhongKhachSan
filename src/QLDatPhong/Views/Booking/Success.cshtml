@{
    ViewBag.Title = "Đặt phòng thành công";
}

<div class="container text-center" style="margin-top: 60px; margin-bottom: 60px;">
    <div class="card shadow-lg border-0 mx-auto" style="max-width: 600px; border-radius: 15px;">
        <div class="card-body py-5">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 80px;"></i>

            <h2 class="mt-4 text-success fw-bold">Đặt phòng thành công!</h2>

            <p class="lead text-muted mt-3">
                Cảm ơn bạn đã lựa chọn Khách Sạn Long An. Đơn đặt phòng của bạn đã được lưu vào hệ thống và đang trong trạng thái <strong>Chờ duyệt</strong>.
            </p>
            <p class="text-secondary">
                Bộ phận lễ tân sẽ liên hệ lại với bạn qua số điện thoại đã cung cấp để xác nhận trong thời gian sớm nhất.
            </p>

            <div class="mt-5">
                <a href="/" class="btn btn-primary btn-lg px-4 rounded-pill">
                    <i class="bi bi-house-door-fill"></i> Về Trang chủ
                </a>
            </div>
        </div>
    </div>
</div>