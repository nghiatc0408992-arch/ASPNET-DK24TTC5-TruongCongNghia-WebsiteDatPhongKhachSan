@model QLDatPhong.Models.Booking

@{
    ViewBag.Title = "Chi tiết Đơn hàng #" + Model.BookingID;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    @@media print {
        .no-print {
            display: none !important;
        }

        .panel {
            border: none !important;
            box-shadow: none !important;
        }
    }
</style>

<div class="container" style="margin-top:20px;">
    <div class="panel panel-info">
        <div class="panel-heading">
            <h3 class="panel-title text-center" style="font-size: 24px; font-weight: bold;">
                HÓA ĐƠN ĐẶT PHÒNG
            </h3>
        </div>
        <div class="panel-body" style="padding: 30px;">
            <div class="row">
                <div class="col-xs-6">
                    <h4><strong>Thông tin khách hàng</strong></h4>
                    <p><strong>Họ tên:</strong> @Model.CustomerName</p>
                    <p><strong>Điện thoại:</strong> @Model.CustomerPhone</p>
                    <p><strong>Ngày đặt:</strong> @Model.CheckInDate.ToShortDateString() - @Model.CheckOutDate.ToShortDateString()</p>
                </div>
                <div class="col-xs-6 text-right">
                    <h4><strong>Mã đơn: #@Model.BookingID</strong></h4>
                    <p>
                        <strong>Trạng thái:</strong>
                        @if (Model.BookingStatus == 0)
                        {<span class="text-warning">Chờ duyệt</span> }
                        else if (Model.BookingStatus == 1)
                        { <span class="text-success">Đã xác nhận</span> }
                        else if (Model.BookingStatus == 2)
                        { <span class="text-primary">Hoàn thành</span> }
                        else
                        { <span class="text-danger">Đã hủy</span>}
                    </p>
                </div>
            </div>

            <hr />

            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>STT</th>
                        <th>Phòng</th>
                        <th>Loại phòng</th>
                        <th>Đơn giá (VNĐ)</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int stt = 1; }
                    @foreach (var detail in Model.BookingDetails)
                    {
                        <tr>
                            <td>@(stt++)</td>
                            <td>@detail.Room.RoomNumber</td>
                            <td>@detail.Room.RoomType.TypeName</td>
                            <td>@detail.Price.ToString("N0")</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="row">
                <div class="col-xs-12 text-right">
                    <h3 class="text-danger"><strong>Tổng cộng: @Model.TotalAmount.ToString("N0") VNĐ</strong></h3>
                </div>
            </div>
        </div>
        <div class="panel-footer text-center no-print">
            <a href="/Booking/Index" class="btn btn-default">Quay lại danh sách</a>
            <button onclick="window.print()" class="btn btn-primary"><i class="glyphicon glyphicon-print"></i> In Hóa Đơn</button>
        </div>
    </div>
</div>