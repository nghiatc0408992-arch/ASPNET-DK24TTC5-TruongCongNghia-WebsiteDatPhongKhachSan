@model QLDatPhong.Models.Booking

@{
    ViewBag.Title = "Xác nhận đặt phòng";
}

<div class="container" style="margin-top:30px;">
    <div class="row">
        <div class="col-md-8 col-md-offset-2">
            <div class="panel panel-primary">
                <div class="panel-heading"><h3 class="panel-title">Thông tin đặt phòng</h3></div>
                <div class="panel-body">
                    <div class="alert alert-warning">
                        <h4>Tóm tắt: @ViewBag.RoomTypeName</h4>
                        <p>Thời gian: <strong>@Model.CheckInDate.ToShortDateString()</strong> đến <strong>@Model.CheckOutDate.ToShortDateString()</strong> (@ViewBag.Nights đêm)</p>
                        <p>Đơn giá: @ViewBag.BasePrice.ToString("N0") VNĐ</p>
                        <hr />
                        <h4 class="text-danger">Tổng cộng: @ViewBag.Total.ToString("N0") VNĐ</h4>
                    </div>

                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="roomTypeId" value="@ViewBag.RoomTypeId" />
                        @Html.HiddenFor(m => m.CheckInDate)
                        @Html.HiddenFor(m => m.CheckOutDate)
                        @Html.HiddenFor(m => m.TotalAmount)

                        <div class="form-group">
                            <label>Họ tên khách hàng:</label>
                            @Html.EditorFor(model => model.CustomerName, new { htmlAttributes = new { @class = "form-control", placeholder = "Nhập họ tên..." } })
                            @Html.ValidationMessageFor(model => model.CustomerName, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group">
                            <label>Số điện thoại:</label>
                            @Html.EditorFor(model => model.CustomerPhone, new { htmlAttributes = new { @class = "form-control", placeholder = "Nhập số điện thoại..." } })
                            @Html.ValidationMessageFor(model => model.CustomerPhone, "", new { @class = "text-danger" })
                        </div>

                        <button type="submit" class="btn btn-success btn-lg btn-block">XÁC NHẬN ĐẶT PHÒNG</button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>